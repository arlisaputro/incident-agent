                }
              ]
            }
          },
          {
            "definition": {
              "title": "\ud83e\udde0 Top Operations",
              "type": "toplist",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "group_by": [
                        {
                          "facet": "resource_name",
                          "limit": 10,
                          "sort": {
                            "aggregation": "count",
                            "order": "desc"
