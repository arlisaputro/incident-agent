                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "\ud83e\ude99 Token Usage Over Time",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "input_tokens",
                      "query": "avg:bedrock.tokens.input{service:incident-agent}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "output_tokens",
                      "query": "avg:bedrock.tokens.output{service:incident-agent}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "input_tokens",
                      "alias": "Input Tokens"
                    },
                    {
                      "formula": "output_tokens",
                      "alias": "Output Tokens"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "bars"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "\u23f1\ufe0f Bedrock Latency Over Time",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent resource_name:InvokeModel"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "avg",
                        "metric": "@duration"
                      },
                      "group_by": []
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "\ud83d\udcc8 Request Volume by Operation",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "group_by": [
                        {
                          "facet": "@resource_name",
                          "limit": 10,
                          "sort": {
                            "aggregation": "count",
                            "order": "desc"
