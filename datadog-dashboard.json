            }
          },
          {
            "definition": {
              "title": "\ud83d\udd0d Latency by Operation",
              "type": "toplist",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "avg",
                        "metric": "@duration"
                      },
                      "group_by": [
                        {
                          "facet": "resource_name",
                          "limit": 10,
                          "sort": {
                            "aggregation": "avg",
                            "metric": "@duration",
                            "order": "desc"
                          }
                        }
                      ]
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "response_format": "scalar"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "\ud83e\udde0 Hallucination Monitoring",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "**Faithfulness Score Guide:**\n\n| Score | Risk | Meaning |\n|-------|------|--------|\n| 1.0 | \u2705 Low | AI output consistent with provided context |\n| 0.5 | \u26a0\ufe0f Medium | AI made some claims not fully backed by context |\n| 0.0 | \ud83d\udea8 High | AI hallucinated \u2014 output contradicts or fabricates data |\n\n**Checks:** fake percentages, phantom alerts, non-existent runbook references",
              "background_color": "white",
              "font_size": "14",
              "text_align": "left",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left"
            }
          },
          {
            "definition": {
              "title": "Faithfulness Score (latest)",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "q1",
                      "query": "avg:llm.hallucination.faithfulness{service:incident-agent}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "q1"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 1
            }
          },
          {
            "definition": {
              "title": "\ud83d\udcc8 Faithfulness Over Time",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "faith",
                      "query": "avg:llm.hallucination.faithfulness{service:incident-agent}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "faith",
                      "alias": "Faithfulness Score (1.0=Safe, 0.0=Hallucinated)"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "\ud83d\udda5\ufe0f Infra Compute (EC2)",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "CPU Utilization (%)",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:system.cpu.user{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Memory Usage",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:system.mem.used{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Disk Usage (%)",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:system.disk.in_use{*} * 100"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "title": "Network In/Out (bytes)",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "net_in",
                      "query": "avg:system.net.bytes_rcvd{*}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "net_out",
                      "query": "avg:system.net.bytes_sent{*}"
                    }
                  ],
                  "response_format": "timeseries",
                  "display_type": "line"
                }
              ]
            }
          }
        ]
      }
    }
  ]
}