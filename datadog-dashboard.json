{
  "title": "\ud83e\udde0 Incident Intelligence Agent - LLM Observability",
  "description": "LLM performance, RAG retrieval, and operational metrics",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "title": "\ud83e\udd16 LLM Performance",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "title": "Total LLM Requests (Bedrock)",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent resource_name:InvokeModel"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "group_by": []
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "Avg LLM Latency",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent resource_name:InvokeModel"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "avg",
                        "metric": "@duration"
                      },
                      "group_by": []
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 2,
              "autoscale": true
            }
          },
          {
            "definition": {
              "title": "LLM Errors",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent resource_name:InvokeModel status:error"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "group_by": []
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "Total Spans",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "spans",
                      "name": "query1",
                      "search": {
                        "query": "service:incident-agent"
                      },
                      "indexes": [
                        "*"
                      ],
                      "compute": {
                        "aggregation": "count"
                      },
                      "group_by": []
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "\ud83e\ude99 Avg Input Tokens",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:bedrock.tokens.input{service:incident-agent}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "\ud83e\ude99 Avg Output Tokens",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:bedrock.tokens.output{service:incident-agent}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "precision": 0
            }
          },
          {
            "definition": {
              "title": "\ud83e\ude99 Total Tokens Used",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:bedrock.tokens.total{service:incident-agent}.as_count()"
